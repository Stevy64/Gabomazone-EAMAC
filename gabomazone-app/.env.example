# ⚠️  Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS committer le fichier .env

SECRET_KEY=changez-moi-avec-une-vraie-clé-de-50-caractères-minimum

DEBUG=False
USE_SQLITE=false

# PostgreSQL
POSTGRES_DB=gabomazone
POSTGRES_USER=gabomazone
POSTGRES_PASSWORD=CHANGEZ_MOI
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/1

# SingPay
SINGPAY_API_KEY=
SINGPAY_API_SECRET=
SINGPAY_MERCHANT_ID=
SINGPAY_DISBURSEMENT_ID=
SINGPAY_ENVIRONMENT=sandbox
SINGPAY_PRODUCTION_DOMAIN=gabomazone.com

# Numéro mobile Gabomazone pour recevoir les commissions
GABOMAZONE_PLATFORM_MOBILE_NUMBER=+24177984050

# SendGrid
SENDGRID_API_KEY=
EMAIL_SENDGRID=contact@gabomazone.com

# Celery
CELERY_BROKER_URL=redis://redis:6379/0

# Hôtes autorisés (séparés par des virgules)
ALLOWED_HOSTS=localhost,127.0.0.1
